# Backend Server Configuration
PORT=3001

# CORS Configuration
# Comma-separated list of origins allowed to make requests to this backend
# Example: http://localhost:5173,https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# JWT Configuration
# A strong, random string used to sign authentication tokens.
# You can generate one using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-that-is-at-least-32-characters-long

# StudyLM Local Database Configuration (Replaces EverMemOS)
# By default, falls back to file:backend/studypod.db locally if testing.
# In production (e.g. VPS), use the absolute path or Turso URL.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Gemini API Keys (Rotation Farm)
# Comma-separated list of keys to bypass rate limits (1500 req/day per key)
GEMINI_API_KEYS=your_first_gemini_key,your_second_gemini_key
